{
  "name": "n8n-ops-mcp",
  "version": "0.14.0",
  "description": "n8nctrl operator control CLI for n8n workflow ops, with MCP and OpenClaw adapters for agents.",
  "type": "module",
  "license": "MIT",
  "author": "Solomon Neas <srneas@gmail.com>",
  "keywords": [
    "n8n",
    "mcp",
    "model-context-protocol",
    "n8nctrl",
    "openclaw",
    "cli",
    "workflow",
    "ops",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lidless-labs/n8nctrl.git"
  },
  "homepage": "https://github.com/lidless-labs/n8nctrl#readme",
  "bugs": {
    "url": "https://github.com/lidless-labs/n8nctrl/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "n8nctrl": "dist/cli.js",
    "n8nctl": "dist/cli.js",
    "n8n-ops": "dist/cli.js",
    "n8n-ops-mcp": "dist/mcp-bin.js"
  },
  "main": "dist/mcp-server.js",
  "files": [
    "dist",
    "index.ts",
    "src",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.22",
      "pluginSdkVersion": "2026.4.22"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sinclair/typebox": "^0.34.0",
    "zod": "^4.3.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "^2026.4.22",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "start": "node dist/mcp-bin.js",
    "cli": "node dist/cli.js",
    "dev": "tsx mcp-server.ts",
    "dev:cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  }
}
